{
  "permissions": {
    "allow": [
      "Bash(./gradlew compileJava)",
      "Bash(./gradlew test:*)",
      "Bash(./gradlew build:*)",
      "Bash(./gradlew clean)",
      "Bash(git add:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git switch:*)"
    ],
    "deny": [
      "Bash(git push:*)",
      "Bash(git commit --no-verify:*)",
      "Bash(git config core.hooksPath:*)",
      "Read(./.env)",
      "Read(./src/main/resources/application-local.yml)",
      "Read(./src/main/resources/application-prod.yml)"
    ]
  }
}
